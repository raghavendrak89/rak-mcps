# /etc/proxmox-mcp/proxmox-mcp.env
# Mode: 0600, owner proxmox-mcp:proxmox-mcp

# --- Proxmox API ---
PROXMOX_MCP_PVE_HOST=pve1.lan
PROXMOX_MCP_PVE_PORT=8006
PROXMOX_MCP_PVE_USER=mcp@pve
PROXMOX_MCP_PVE_TOKEN_NAME=mcp
PROXMOX_MCP_PVE_TOKEN_VALUE=REPLACE-WITH-UUID-FROM-PVE
# Set to false ONLY if you use self-signed PVE certs and accept the risk:
PROXMOX_MCP_PVE_VERIFY_SSL=true

# --- MCP transport ---
# Bind to the Tailscale interface IP of THIS VM, not 0.0.0.0.
# Find it with: tailscale ip -4
PROXMOX_MCP_BIND_HOST=100.x.y.z
PROXMOX_MCP_BIND_PORT=8080
PROXMOX_MCP_TRANSPORT=streamable-http

# --- Safety ---
PROXMOX_MCP_ALLOW_DESTRUCTIVE=true
PROXMOX_MCP_TASK_WAIT_TIMEOUT=300
PROXMOX_MCP_LOG_LEVEL=INFO
